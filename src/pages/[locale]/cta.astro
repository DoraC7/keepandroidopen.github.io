---
/**
 * Localized CTA (Call to Action) page at /{locale}/cta/
 * Renders the content collection markdown for the given locale.
 */
import { getCollection, render } from 'astro:content';
import Default from '../../layouts/Default.astro';
import SharedLinks from '../../components/SharedLinks.astro';
import Regulators from '../../components/Regulators.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages
    .filter((page) => page.id !== 'letter')
    .filter((page) => page.id !== 'banner')
    .map((page) => {
      const locale = page.id;
      return { params: { locale }, props: { entry: page } };
    });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
---
<Default {...data}>
  <Content />
  <Regulators locale={data.lang} />
  <SharedLinks locale={data.lang} />
</Default>
